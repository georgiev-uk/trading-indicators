# ── Required ──────────────────────────────────────────
# None of the core scripts (01–07) require API keys.
# All free data sources used are unauthenticated.

# ── Optional ──────────────────────────────────────────

# LunarCrush (Script 08 — paid subscription required)
# Get your API key at: https://lunarcrush.com/developers/api/authentication
LUNARCRUSH_API_KEY=

# Timezone for displaying macro event times in morning briefing
# Default: UTC. Example: Europe/London, America/New_York
TIMEZONE=Europe/London
